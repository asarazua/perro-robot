// --- INICIO: COMUNICACIÓN CON DIGITALOCEAN (MONGODB) ---
void postEvento(String tipo, String descripcion) {
  if(WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    http.begin(String(serverUrl) + "/evento"); 
    http.addHeader("Content-Type", "application/json");
    String json = "{\"tipo\":\"" + tipo + "\",\"descripcion\":\"" + descripcion + "\"}"; 
    http.POST(json);
    http.end();
  }
}

void addLog(String tipo, String desc) {
  postEvento(tipo, desc);
  Serial.println("Log enviado a MongoDB: " + desc);
}
// --- FIN: COMUNICACIÓN CON DIGITALOCEAN (MONGODB) ---

// --- INICIO: FUNCIONES DE BAJO NIVEL ---
int usToPCA(int us) { return map(us, 500, 2500, 102, 512); }
int corregir(int id, int v) {
  if (invertido[id]) return centro[id] - (v - centro[id]);
  return v;
}
void writeServo(int id, int us) {
  currentPos[id] = us;
  pca.setPWM(ch[id], 0, usToPCA(corregir(id, us)));
}
void Move(int id, int target, int speed, void(*cb)() = NULL) {
  tasks[id].target = target;
  tasks[id].speed = speed;
  tasks[id].callback = cb;
  tasks[id].active = true;
}
void fin_ciclo() { flag = true; }

