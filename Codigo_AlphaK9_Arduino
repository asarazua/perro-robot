// --- INICIO: SISTEMA OPERATIVO Y COMUNICACION ---
void handlePostInstruccion() {
  if (server.hasArg("plain")) {
    String body = server.arg("plain");
    if (body.indexOf("adelante") > 0)       command = 'F';
    else if (body.indexOf("atras") > 0)     command = 'B';
    else if (body.indexOf("sentar") > 0)    command = 'H';
    else if (body.indexOf("flexionar") > 0) command = 'J';
    else if (body.indexOf("estirar") > 0)   command = 'K';
    else if (body.indexOf("inicio") > 0)    command = 'P';
    else if (body.indexOf("stop") > 0)      command = 'S';
    else if (body.indexOf("ip") > 0)        command = 'M';
    server.send(200, "application/json", "{\"status\":\"ok\"}");
  }
}

void checkPendientes() {
  static unsigned long lastCheck = 0;
  if (millis() - lastCheck < 3000) return; 
  lastCheck = millis();

  if(WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  http.setTimeout(5000);  // mas tiempo
  http.begin(String(serverUrl) + "/instruccion/pendiente"); 
  int httpCode = http.GET();
  
  if (httpCode == 200) {
    String payload = http.getString();
    Serial.println("Instruccion recibida: " + payload); // para debug
    
    // buscar el comando en el JSON
    int idx = payload.indexOf("\"comando\":\"");
    if (idx > 0) {
      int start = idx + 11;
      int end = payload.indexOf("\"", start);
      String cmd = payload.substring(start, end);
      
      Serial.println("Comando extraido: " + cmd);
      
      if (cmd == "adelante")       command = 'F';
      else if (cmd == "atras")     command = 'B';
      else if (cmd == "sentar")    command = 'H';
      else if (cmd == "flexionar") command = 'J';
      else if (cmd == "estirar")   command = 'K';
      else if (cmd == "inicio")    command = 'P';
      else if (cmd == "stop")      command = 'S';
      else if (cmd == "ip")        command = 'M';
    }
  } else {
    Serial.println("Error HTTP: " + String(httpCode));
  }
  http.end();
}

void updateServos() {
  static unsigned long last = 0;
  if (millis() - last < 15) return;
  last = millis();
  for (int i = 0; i < 9; i++) {
    if (!tasks[i].active) continue;
    if (currentPos[i] < tasks[i].target) {
      currentPos[i] += tasks[i].speed;
      if (currentPos[i] > tasks[i].target) currentPos[i] = tasks[i].target;
    } else if (currentPos[i] > tasks[i].target) {
      currentPos[i] -= tasks[i].speed;
      if (currentPos[i] < tasks[i].target) currentPos[i] = tasks[i].target;
    }
    writeServo(i, currentPos[i]);
    if (currentPos[i] == tasks[i].target) {
      tasks[i].active = false;
      if (tasks[i].callback != NULL) {
        void (*cb)() = tasks[i].callback;
        tasks[i].callback = NULL;
        cb();
      }
    }
  }
}

void setup() {
  Serial.begin(115200);
  SerialBT.begin("Aston_ESP32");
  WiFi.mode(WIFI_AP_STA); 
  WiFi.begin("sjdcp", "sjdcp1604"); 

  Serial.print("Conectando a WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println(" conectado!");
  
  server.on("/instruccion", HTTP_POST, handlePostInstruccion); 
  server.begin();

  Wire.begin(21, 22);
  pca.begin();
  pca.setPWMFreq(50);
  delay(1000);

  // Mostrar IP al arrancar
  mostrarIP();
  
  addLog("sensor", "Sistema Aston Iniciado / Pose Inicial");
  pose_inicio();
}

void loop() {
  if (SerialBT.available()) {
    command = SerialBT.read();
  } else if (Serial.available()) {
    char t = Serial.read();
    if (t != '\n' && t != '\r') command = t;
  }
  
  server.handleClient();
  checkPendientes(); 

  // --- CONTROL EXCLUSIVO DE LOGS POR CAMBIO DE COMANDO ---
  if (command != lastCommand) {
    Serial.print("Nuevo comando detectado: "); Serial.println(command);
    switch (command) {
      case 'F': addLog("movimiento", "Caminando adelante"); break;
      case 'B': addLog("movimiento", "Caminando atras"); break;
      case 'J': addLog("movimiento", "Realizando flexion"); break;
      case 'H': addLog("movimiento", "Robot sentado"); break;
      case 'K': addLog("movimiento", "Modo estirado"); break;
      case 'P': 
      case 'I': addLog("sensor", "Restaurando Pose Inicial"); break;
      case 'S': addLog("movimiento", "Robot Parado / En espera"); break;
      case 'M': mostrarIP(); break;
      case '?': mostrarMenu(); break;
    }
    lastCommand = command;
  }

  // --- EJECUCIÓN CONTINUA DE LOS MOTORES ---
  if (flag && command != 'S') {
    switch (command) {
      case 'F': adelante(); break;
      case 'B': atras(); break;
      case 'J': flexion(); break;
      case 'H': sentado(); break;
      case 'K': estirado(); break;
      case 'P': 
      case 'I': pose_inicio(); break;
      case 'M': command = 'S'; break;
      case '?': command = 'S'; break; 
      default:  command = 'S'; break;
    }
  }
  
  updateServos();
  delay(1);
}
// --- FIN: SISTEMA OPERATIVO Y COMUNICACION ---
